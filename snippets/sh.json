{
  "SLURM Batch Header": {
    "prefix": "sbatch",
    "body": [
      "#SBATCH --job-name=$1",
      "#SBATCH --output=%x-%j.out",
      "#SBATCH --error=%x-%j.out",
      "#SBATCH --account=s1460",
      "#SBATCH --time=0:30:00",
      "#SBATCH --no-requeue",
      "$0"
    ],
    "description": "Insert SLURM standard batch header"
  }
}
